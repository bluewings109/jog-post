# Google OAuth (로그인/인증)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Health(Health Auto Export) 연동은 별도 환경변수 불필요
# — 프로필 페이지에서 사용자별 webhook_secret을 발급받아 DB(data_sources)에 저장함

# Database
DATABASE_URL=postgresql+asyncpg://jogpost:jogpost@localhost:5432/jogpost
# docker-compose.prod.yml 사용 시 db 컨테이너 비밀번호로 쓰임 (운영에서는 강한 값으로 교체)
POSTGRES_PASSWORD=jogpost

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# LLM (나중에 결정)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
ADVICE_ENABLED=true   # AI 조언 기능 on/off. false로 두면 API가 404, 프론트 UI도 숨겨짐

# App
FRONTEND_URL=http://localhost:5173
# 프로덕션(라즈베리파이 자가호스팅) 예시: FRONTEND_URL=https://jog.onlypearson.com
