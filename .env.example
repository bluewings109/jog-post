# Google OAuth (로그인/인증)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Strava OAuth (데이터 연동)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=jog-post-webhook

# Database
DATABASE_URL=postgresql+asyncpg://jogpost:jogpost@localhost:5432/jogpost
# docker-compose.prod.yml 사용 시 db 컨테이너 비밀번호로 쓰임 (운영에서는 강한 값으로 교체)
POSTGRES_PASSWORD=jogpost

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# LLM (나중에 결정)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# App
FRONTEND_URL=http://localhost:5173
# 프로덕션(라즈베리파이 자가호스팅) 예시: FRONTEND_URL=https://jog.onlypearson.com
